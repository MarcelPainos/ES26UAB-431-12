<mxfile host="Electron">
  <diagram name="Página-1" id="cercar_cuiner_plat">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10">
      <root>

        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- PARTICIPANTS -->

        <mxCell id="client" value="Client"
